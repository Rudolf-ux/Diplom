# Скопируй этот файл в .env и подставь свои значения.

# Строка подключения к PostgreSQL.
# Формат: postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/БАЗА
# Пароль — тот, что задавали при установке PostgreSQL для пользователя postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dropzone?schema=public"

# Секрет для подписи JWT-токенов. Замени на длинную случайную строку.
JWT_SECRET="change-me-to-a-long-random-secret"

# Порт, на котором слушает API-сервер.
PORT=4000
