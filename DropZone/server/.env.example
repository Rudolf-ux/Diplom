# Скопируй этот файл в .env и при необходимости поправь значения.

# База данных — SQLite (файл рядом с проектом, ничего ставить не нужно).
DATABASE_URL="file:./dev.db"

# Секрет для подписи JWT-токенов. Замени на длинную случайную строку.
JWT_SECRET="change-me-to-a-long-random-secret"

# Порт, на котором слушает API-сервер.
PORT=4000
